# Environment variables for The Intelligent Bistro Backend API

# The port the API will run on (default is 3001)
PORT=3001

# AI provider configuration. Use either OpenAI or Gemini-compatible settings.
# OpenAI:
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_MODEL=gpt-4o-mini

# Gemini via OpenAI-compatible endpoint:
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_MODEL=gemini-1.5-flash
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
