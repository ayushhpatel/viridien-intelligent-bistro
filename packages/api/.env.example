# Environment variables for The Intelligent Bistro Backend API

# The port the API will run on (default is 3001)
PORT=3001

# Your Gemini API Key (Required for conversational ordering)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override the model used (defaults to gemini-1.5-flash)
GEMINI_API_MODEL=gemini-1.5-flash

# Optional: Override the base URL if using a specific proxy
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
